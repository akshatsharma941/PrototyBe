# ─── PyBe backend configuration ─────────────────────────────────────────
#
# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored; `.env.example` is the documented contract.

# ─── Gemini API key ─────────────────────────────────────────────────────
#
# A Gemini API key is a 39-character string starting with `AIza`. Generate
# one at https://aistudio.google.com/apikey (free tier is fine for
# development).
#
# IMPORTANT: paste the API key itself here, NOT an OAuth access token. The
# Gemini API rejects OAuth access tokens / bearer tokens sent as an API key
# with `401 Unauthorized — ACCESS_TOKEN_TYPE_UNSUPPORTED`.
#
# A real Gemini API key looks like:
#   GEMINI_API_KEY=AIzaSy...   (39 chars, starts with AIza)
#
# An OAuth access token (e.g. from `gcloud auth print-access-token`) looks
# like `ya29....` or `AQ....`. Those go in `Authorization: Bearer …`
# headers, not in this variable.
#
GEMINI_API_KEY=AIzaSyReplaceMeWithARealKeyFromGoogleAIStudio

# ─── MongoDB ────────────────────────────────────────────────────────────
#
# Leave unset to use the embedded `mongodb-memory-server` (no install
# needed). Set this to a real Mongo connection string (e.g. Atlas) for
# production or to share data with a teammate.
#
# Example formats:
#   MONGO_URI=mongodb://127.0.0.1:27017/pybe          # local Mongo
#   MONGO_URI=mongodb+srv://user:pass@cluster/...      # MongoDB Atlas
#
# MONGO_URI=

# ─── Server port ────────────────────────────────────────────────────────
# PORT=5000