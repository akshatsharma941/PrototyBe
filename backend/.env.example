# ─── PyBe backend configuration ─────────────────────────────────────────
#
# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored; `.env.example` is the documented contract.

# ─── Gemini API key ─────────────────────────────────────────────────────
#
# Generate a key at https://aistudio.google.com/apikey (free tier is fine
# for development).
#
# Google issues two key formats — both are valid Gemini API keys:
#   GEMINI_API_KEY=AIzaSy...   (legacy format, 39 chars)
#   GEMINI_API_KEY=AQ.Ab8...   (new 2025+ "Authentication Key" format)
#
# IMPORTANT:
# - Paste the key with NO leading/trailing spaces.
# - Do NOT use OAuth access tokens (ya29...) here — those go in
#   `Authorization: Bearer …` headers, not in this variable.
#
GEMINI_API_KEY=REPLACE_ME_WITH_YOUR_GEMINI_API_KEY

# ─── MongoDB ────────────────────────────────────────────────────────────
#
# Leave unset to use the embedded `mongodb-memory-server` (no install
# needed). Set this to a real Mongo connection string (e.g. Atlas) for
# production or to share data with a teammate.
#
# Example formats:
#   MONGO_URI=mongodb://127.0.0.1:27017/pybe          # local Mongo
#   MONGO_URI=mongodb+srv://user:pass@cluster/...      # MongoDB Atlas
#
# MONGO_URI=

# ─── Server port ────────────────────────────────────────────────────────
# PORT=5000